{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/forms/**",
              "components/product/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Newsreader|Hanken Grotesk|Space Mono))/i]",
        "message": "Font not provided by the design system. Available: Newsreader, Hanken Grotesk, Space Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute > JSXIdentifier[name!=/^(?:src|name|size|style|key|ref|className|style|children)$/]",
        "message": "<Avatar> doesn't accept that prop. Declared props: src, name, size, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|full|disabled|leadingIcon|trailingIcon|children|style|onClick|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, full, disabled, leadingIcon, trailingIcon, children, style, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|ghost|subtle|accent|apple)$/]",
        "message": "<Button> variant must be one of 'primary' | 'ghost' | 'subtle' | 'accent' | 'apple'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:raised|pad|children|style|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: raised, pad, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Chip'] > JSXAttribute > JSXIdentifier[name!=/^(?:on|leadingIcon|children|style|onClick|key|ref|className|style|children)$/]",
        "message": "<Chip> doesn't accept that prop. Declared props: on, leadingIcon, children, style, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|multiline|maxLength|value|placeholder|onChange|style|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: label, multiline, maxLength, value, placeholder, onChange, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ListRow'] > JSXAttribute > JSXIdentifier[name!=/^(?:leading|title|subtitle|trailing|last|style|onClick|key|ref|className|style|children)$/]",
        "message": "<ListRow> doesn't accept that prop. Declared props: leading, title, subtitle, trailing, last, style, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='Mascot'] > JSXAttribute > JSXIdentifier[name!=/^(?:stage|size|style|key|ref|className|style|children)$/]",
        "message": "<Mascot> doesn't accept that prop. Declared props: stage, size, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='PhotoFrame'] > JSXAttribute > JSXIdentifier[name!=/^(?:src|alt|height|rounded|protect|overlay|children|style|key|ref|className|style|children)$/]",
        "message": "<PhotoFrame> doesn't accept that prop. Declared props: src, alt, height, rounded, protect, overlay, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Segment'] > JSXAttribute > JSXIdentifier[name!=/^(?:options|value|onChange|style|key|ref|className|style|children)$/]",
        "message": "<Segment> doesn't accept that prop. Declared props: options, value, onChange, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Sheet'] > JSXAttribute > JSXIdentifier[name!=/^(?:open|title|onClose|children|style|key|ref|className|style|children)$/]",
        "message": "<Sheet> doesn't accept that prop. Declared props: open, title, onClose, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Stepper'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|defaultValue|min|max|onChange|style|key|ref|className|style|children)$/]",
        "message": "<Stepper> doesn't accept that prop. Declared props: value, defaultValue, min, max, onChange, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='StreakBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:weeks|label|message|style|key|ref|className|style|children)$/]",
        "message": "<StreakBar> doesn't accept that prop. Declared props: weeks, label, message, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|leadingIcon|children|style|key|ref|className|style|children)$/]",
        "message": "<Tag> doesn't accept that prop. Declared props: tone, leadingIcon, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:neutral|action|accent|success)$/]",
        "message": "<Tag> tone must be one of 'neutral' | 'action' | 'accent' | 'success'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Toggle'] > JSXAttribute > JSXIdentifier[name!=/^(?:on|defaultOn|onChange|style|key|ref|className|style|children)$/]",
        "message": "<Toggle> doesn't accept that prop. Declared props: on, defaultOn, onChange, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Trip'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|club|kind|when|cost|photo|going|goingN|key|ref|className|style|children)$/]",
        "message": "<Trip> doesn't accept that prop. Declared props: title, club, kind, when, cost, photo, going, goingN."
      },
      {
        "selector": "JSXOpeningElement[name.name='Trip'] > JSXAttribute[name.name='kind'] > Literal[value!=/^(?:Adventure|Activity)$/]",
        "message": "<Trip> kind must be one of 'Adventure' | 'Activity'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
